NODE_ENV=development
PORT=3000
# Local: 127.0.0.1. En Heroku/producción usar 0.0.0.0 o dejar sin definir.
HOST=127.0.0.1
DATABASE_URL=postgresql://magiccity:magiccity@localhost:5432/magiccity?schema=public
# Lista exacta separada por comas. Para LAN temporal agrega tu IP:
# http://localhost:5173,http://127.0.0.1:5173,http://192.168.68.121:5173,file://,null
# Para Netlify + Electron:
# https://tu-app.netlify.app,file://,null
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=mc_session
CSRF_COOKIE_NAME=mc_csrf
# Local/LAN HTTP: lax + COOKIE_SECURE vacío o false.
# Netlify/Heroku HTTPS cross-site: none + true.
COOKIE_SAME_SITE=lax
COOKIE_SECURE=
# Default actual del código: 720 minutos de inactividad y 720 horas absolutas.
# Para prod testing evita expiraciones cortas; baja estos valores solo cuando ya definas política final.
SESSION_INACTIVITY_TIMEOUT_MINUTES=720
SESSION_ABSOLUTE_TIMEOUT_HOURS=720
# Testing inicial: genera links wa.me, no envía mensajes reales.
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=whatsapp_link
WHATSAPP_DEFAULT_COUNTRY_CODE=52
WHATSAPP_BUSINESS_PHONE=+52 55 1234 5678
# Reservado para una integración futura como WhatsApp Cloud API.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM=
WHATSAPP_TIMEOUT_MS=4000
PAYMENT_BANK_NAME=Banco Ejemplo MX
PAYMENT_ACCOUNT_HOLDER=MAGIC CITY EVENTOS S.A. DE C.V.
PAYMENT_ACCOUNT_NUMBER=1234567890123456
PAYMENT_CLABE=012345678901234567
PAYMENT_REFERENCE_HINT=Nombre del titular de la reserva
BUSINESS_WHATSAPP=+52 55 1234 5678
BUSINESS_PHONE=+52 55 9876 5432
BUSINESS_EMAIL=pagos@magiccitydemo.com
LOG_LEVEL=log,warn,error
